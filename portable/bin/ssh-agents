#!/usr/bin/env -S python-venv --virtualenv dotfiles
import dataclasses
import logging
import os
import pathlib
import re
import shlex
import subprocess
import sys
from concurrent import futures

import paramiko
import psutil
from jmullan.cmd import cmd
from jmullan.logging.easy_logging import easy_initialize_logging

logger = logging.getLogger(__name__)


@dataclasses.dataclass
class FlatKey:
    name: str
    algorithm_name: str
    fingerprint: str
    base64: str
    can_sign: bool
    comment: str


@dataclasses.dataclass
class AgentSocket:
    path: pathlib.Path
    owners: list[dict]
    keys: list[FlatKey]


@dataclasses.dataclass
class AgentCorrelationRow:
    pid: int | None
    socket: pathlib.Path | None
    key: FlatKey | None

    def best_key_path(self, key_paths_by_fingerprint: dict[str, set[str]]) -> str | None:
        if self.key is None:
            return None
        fingerprint = self.key.fingerprint
        if fingerprint is None:
            return None
        if not key_paths_by_fingerprint:
            return None
        return [key_path for key_path in sorted(key_paths_by_fingerprint[fingerprint], key=lambda x: len(x))][0]


def processes_with_file_open(file_path: pathlib.Path) -> list[dict]:
    command = ["lsof", "-FpLc0", file_path]
    logger.debug(f"{' '.join(str(x) for x in command)}")
    results = []
    with subprocess.Popen(
        command, stdout=subprocess.PIPE, stderr=subprocess.PIPE, encoding="UTF8"
    ) as proc:
        lines = proc.stdout.readlines()
        for line in lines:
            if line is None:
                continue
            line = line.strip("\n\r")
            if len(line) < 2:
                # the field name is a letter, and the value must be at least
                # one character
                continue
            fields = {k[0]: k[1:] for k in line.split("\0") if len(k)}
            if not fields or "p" not in fields or "c" not in fields:
                continue
            fields["filename"] = str(file_path)
            results.append(fields)
    return results


def ssh_agent_processes() -> list[int]:
    uid = os.getuid()
    results = []
    for p in psutil.process_iter(["pid", "name", "uids"]):
        try:
            if not p.info["name"] or p.info["name"] != "ssh-agent":
                continue
            if not p.info["uids"] or p.info["uids"].real != uid:
                continue
            results.append(int(p.info["pid"]))
        except (psutil.NoSuchProcess, psutil.AccessDenied):
            pass
    return results


def flatten_key(agent_key: paramiko.AgentKey) -> FlatKey:
    return FlatKey(
        agent_key.get_name(),
        agent_key.algorithm_name,
        agent_key.fingerprint,
        agent_key.get_base64(),
        agent_key.can_sign(),
        agent_key.comment
    )

def _list_keys(socket_path: pathlib.Path) -> list[FlatKey]:
    """Running _list_keys in a new process to not have to manage the
    environment.
    """
    os.environ["SSH_AUTH_SOCK"] = str(socket_path)
    return [flatten_key(key) for key in paramiko.Agent().get_keys()]


def list_keys(socket_path: pathlib.Path) -> list[FlatKey]:
    with futures.ProcessPoolExecutor(max_workers=1) as ex:
        return ex.submit(_list_keys, socket_path).result()


def list_agent_sockets() -> dict[pathlib.Path, AgentSocket]:
    results: dict[pathlib.Path, AgentSocket] = dict()

    agent_dir = (pathlib.Path("~") / ".ssh" / "agent").expanduser()
    if agent_dir.is_dir():
        for file_path in agent_dir.glob("**/*"):
            if file_path.is_socket():
                owners = processes_with_file_open(file_path)
                keys = list_keys(file_path)
                results[file_path] = AgentSocket(file_path, owners, keys)
        if results:
            return results
    for file_path in pathlib.Path("/tmp").glob("ssh-*/agent.*"):
        if file_path.is_socket():
            owners = processes_with_file_open(file_path)
            keys = list_keys(file_path)
            results[file_path] = AgentSocket(file_path, owners, keys)
    return results


class Main(cmd.Main):
    def __init__(self):
        super().__init__()
        select = self.parser.add_mutually_exclusive_group()
        select.add_argument(
            "--best", dest="select", action="store_const", default="best", const="best", help="Pick the best agent"
        )
        select.add_argument(
            "--blessed", dest="select", action="store_const", const="blessed", help="Only show agents with a pid AND socket"
        )
        select.add_argument(
            "--cursed", dest="select", action="store_const", const="cursed", help="Anything not blessed"
        )
        select.add_argument(
            "--loose-sockets", dest="select", action="store_const", const="loose-sockets", help="Pick loose sockets"
        )
        select.add_argument(
            "--loose-pids", dest="select", action="store_const", const="loose-pids", help="Pick pids with no sockets"
        )
        select.add_argument(
            "--all", dest="select", action="store_const", const="all", help="Pick all pids and sockets"
        )
        self.parser.add_argument(
            "--pid", dest="output", action="append_const", const="pids", help="Print the pid(s)"
        )
        self.parser.add_argument(
            "--socket", dest="output", action="append_const", const="sockets", help="Print the socket(s)"
        )
        self.parser.add_argument(
            "--key", dest="output", action="append_const", const="keys", help="Print the key(s)"
        )
        self.parser.add_argument(
            "--exports", dest="exports", action="store_true", default=False, help="Print exports"
        )
        self.parser.add_argument(
            "--unsets", dest="unsets", action="store_true", default=False, help="Print unset"
        )
        self.parser.add_argument(
            "--if", dest="no_output", action="store_true", default=False, help="Only exit 0 or 1 if there is at least one matching entry"
        )


    def setup(self):
        super().setup()
        if self.args.verbose:
            easy_initialize_logging("DEBUG", stream=sys.stderr)
        else:
            easy_initialize_logging("INFO", stream=sys.stderr)


    def main(self):
        super().main()
        processes = ssh_agent_processes()
        agent_sockets = list_agent_sockets()
        agent_sockets_by_process: dict[int, list[AgentSocket]] = dict()
        for pid in processes:
            agent_sockets_by_process[pid] = []
        loose_socket_paths = []
        for socket_path, agent_socket in agent_sockets.items():
            if not agent_socket.owners:
                loose_socket_paths.append(socket_path)
            for owner in agent_socket.owners:
                if not owner:
                    continue
                pid_string = owner.get("p")
                if not pid_string or not re.match(r"^[0-9]+$", pid_string):
                    continue
                pid = int(pid_string)
                if pid not in agent_sockets_by_process:
                    agent_sockets_by_process[pid] = []
                agent_sockets_by_process[pid].append(agent_socket)
        joined: list[AgentCorrelationRow] = []
        for pid, agent_sockets in agent_sockets_by_process.items():
            if not agent_sockets:
                joined.append(AgentCorrelationRow(pid, None, None))
            for agent_socket in agent_sockets:
                if not agent_socket.keys:
                    joined.append(AgentCorrelationRow(pid, agent_socket.path, None))
                for key in agent_socket.keys:
                    joined.append(AgentCorrelationRow(pid, agent_socket.path, key))
        for agent_socket_path in loose_socket_paths:
            joined.append(AgentCorrelationRow(None, agent_socket_path, None))
        filtered: list[AgentCorrelationRow] = []
        if self.args.select == "best":
            have_pids = [row for row in joined if row.pid is not None]
            best = None
            if have_pids:
                best = have_pids[0]
                have_sockets = [row for row in have_pids if row.socket is not None]
                if have_sockets:
                    best = have_sockets[0]
                    have_keys = [row for row in have_sockets if row.key is not None]
                    if have_keys:
                        best = have_keys[0]
            if best:
                filtered = [best]
        elif self.args.select == "blessed":
            filtered, _ = partition_by_sanctity(joined)
        elif self.args.select == "cursed":
            _, filtered = partition_by_sanctity(joined)
        elif self.args.select == "loose-sockets":
            filtered = [row for row in joined if row.pid is None]
        elif self.args.select == "loose-pids":
            filtered = [row for row in joined if row.socket is None]
        elif self.args.select == "all":
            filtered = joined
        if self.args.no_output:
            if filtered:
                exit(0)
            else:
                exit(1)

        if self.args.exports or self.args.unsets:
            pid = None
            socket = None
            if filtered:
                row = filtered[0]
                pid = row.pid
                socket = row.socket
            if self.args.exports:
                if pid is not None:
                    pid = shlex.quote(str(pid))
                    print(f"export SSH_AGENT_PID={pid}")
                if socket is not None:
                    socket = shlex.quote(str(socket))
                    print(f"export SSH_AUTH_SOCK={socket}")
            if self.args.unsets:
                if pid is None:
                    print("unset SSH_AGENT_PID")
                if socket is None:
                    print("unset SSH_AUTH_SOCK")
            if pid is not None and socket is not None:
                exit(0)
            else:
                exit(1)
        else:
            key_paths_by_fingerprint: dict[str, set[str]] = {}
            for row in filtered:
                populate_key_paths(row.key, key_paths_by_fingerprint)
            for row in filtered:
                parts = []
                if not self.args.output or "pids" in self.args.output:
                    parts.append(row.pid)
                if not self.args.output or "sockets" in self.args.output:
                    parts.append(row.socket)
                if not self.args.output or "keys" in self.args.output:
                    parts.append(row.best_key_path(key_paths_by_fingerprint))
                parts = [str(x if x is not None else "") for x in parts]
                maybe = "".join(parts)
                if len(maybe) > 0:
                    print("\t".join(parts))


def partition_by_sanctity(rows: list[AgentCorrelationRow]) -> tuple[list[AgentCorrelationRow], list[AgentCorrelationRow]]:
    blessed = []
    cursed = []
    for row in rows:
        if row.pid is not None and row.socket is not None and row.key is not None:
            blessed.append(row)
        else:
            cursed.append(row)
    if blessed:
        return blessed, cursed

    for row in rows:
        if row.pid is not None and row.socket is not None:
            blessed.append(row)
        else:
            cursed.append(row)
    return blessed, cursed


def populate_key_paths(flat_key: FlatKey, key_paths_by_fingerprint: dict[str, set[str]]) -> None:
    if flat_key is None or flat_key.fingerprint is None:
        return
    fingerprint = flat_key.fingerprint
    if fingerprint not in key_paths_by_fingerprint:
        key_paths_by_fingerprint[fingerprint] = set()
    comment = flat_key.comment
    if comment is not None and comment not in key_paths_by_fingerprint[fingerprint]:
        comment_path = pathlib.Path(comment).expanduser()
        if comment_path.exists():
            key_paths_by_fingerprint[fingerprint].add(comment)


if __name__ == "__main__":
    Main().main()
